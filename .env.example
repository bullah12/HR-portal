# PostgreSQL connection string used by Prisma (datasource in prisma/schema.prisma).
# Production runs on AWS RDS in eu-central-1; use a local instance for development.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hr_portal?schema=public"

# Secret used to sign/verify HS256 JWTs issued by POST /api/auth/login.
# Generate one with: openssl rand -base64 48
AUTH_SECRET="replace-me-with-a-long-random-secret"

# Directory (relative to the project root) where uploaded CVs are stored.
# Production uses S3 (eu-central-1, SSE-KMS); local dev writes to disk.
CV_UPLOAD_DIR="uploads/cv"

# Microsoft 365 Graph calendar integration (spec section 6). When all four
# are set, interview scheduling creates real calendar events with Teams
# links via the client-credentials flow; when unset, a local development
# provider generates deterministic event ids and join links instead.
MS_GRAPH_TENANT_ID=""
MS_GRAPH_CLIENT_ID=""
MS_GRAPH_CLIENT_SECRET=""
# Mailbox that owns the interview calendar, e.g. recruiting@company.com
MS_GRAPH_ORGANIZER_UPN=""
