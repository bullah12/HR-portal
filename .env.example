# PostgreSQL connection string used by Prisma (datasource in prisma/schema.prisma).
# Production runs on AWS RDS in eu-central-1; use a local instance for development.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hr_portal?schema=public"

# Secret used to sign/verify HS256 JWTs issued by POST /api/auth/login.
# Generate one with: openssl rand -base64 48
AUTH_SECRET="replace-me-with-a-long-random-secret"

# Directory (relative to the project root) where uploaded CVs are stored.
# Production uses S3 (eu-central-1, SSE-KMS); local dev writes to disk.
CV_UPLOAD_DIR="uploads/cv"

# Directory for onboarding documents (contract, tax forms, NDA). Same
# storage story as CVs: S3 SSE-KMS in production, local disk in dev.
ONBOARDING_UPLOAD_DIR="uploads/onboarding"

# Microsoft 365 Graph calendar integration (spec section 6). When all four
# are set, interview scheduling creates real calendar events with Teams
# links via the client-credentials flow; when unset, a local development
# provider generates deterministic event ids and join links instead.
MS_GRAPH_TENANT_ID=""
MS_GRAPH_CLIENT_ID=""
MS_GRAPH_CLIENT_SECRET=""
# Mailbox that owns the interview calendar, e.g. recruiting@company.com
MS_GRAPH_ORGANIZER_UPN=""

# Public base URL of this app — used in apply links sent to job boards.
APP_BASE_URL="http://localhost:3000"

# --- Job board multiposting: Broadbean aggregator (spec section 6) --------
# When both are set, POST /api/jobs/[id]/post-to-boards pushes postings via
# the aggregator; when unset, a local development mode simulates postings.
BROADBEAN_API_URL=""
BROADBEAN_API_KEY=""

# --- Background checks: Zinc (spec section 6) -----------------------------
# API credentials for ordering checks; webhook secret verifies the HMAC
# (hex, x-webhook-signature header) on POST /api/webhooks/backgroundCheck.
ZINC_API_URL=""
ZINC_API_KEY=""
ZINC_WEBHOOK_SECRET=""

# --- E-signature: DocuSign, EU datacentre (spec section 6) ----------------
# Envelope creation for offer letters; webhook secret verifies the HMAC
# (base64, x-docusign-signature-1 header) on POST /api/webhooks/esign.
DOCUSIGN_BASE_URL=""
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_ACCESS_TOKEN=""
DOCUSIGN_WEBHOOK_SECRET=""

# --- Slack notifications ---------------------------------------------------
# Incoming webhook URL for the recruitment channel. Unset = messages are
# logged locally instead of sent (development mode).
SLACK_WEBHOOK_URL=""
